{
  "expo": {
    "name": "Fidati Pro",
    "slug": "fidati-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fidati-pro",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fidati.pro",
      "infoPlist": {
        "NSCameraUsageDescription": "Fidati Pro usa la fotocamera per scansionare documenti d'identità e selfie di verifica."
      }
    },
    "android": {
      "package": "com.fidati.pro",
      "permissions": ["CAMERA"],
      "adaptiveIcon": {
        "backgroundColor": "#07254A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#07254A"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Fidati Pro usa la galleria per foto profilo, documenti e portfolio.",
          "cameraPermission": "Fidati Pro usa la fotocamera per selfie e foto lavori."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Fidati Pro usa la fotocamera per scansionare documenti d'identità e selfie di verifica.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
